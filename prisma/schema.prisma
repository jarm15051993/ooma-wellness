generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  lastName  String?
  phone     String?  @unique
  birthday  DateTime?
  goals               String?
  additionalInfo      String?
  profilePicture      String?
  activationToken     String?  @unique
  activatedAt         DateTime?
  pendingEmail              String?
  emailChangeToken          String?  @unique
  emailChangeTokenExpiresAt DateTime?
  onboardingCompleted Boolean  @default(false)
  qrCode              String?  @unique
  isAdmin               Boolean  @default(false) // deprecated — use role
  role                  UserRole @default(USER)
  canCreateClass        Boolean  @default(false)
  canViewStudents       Boolean  @default(false)
  canValidateAttendance Boolean  @default(false)
  canBulkUpload         Boolean  @default(false)
  canMarkAsStudent      Boolean  @default(false)
  isStudent             Boolean  @default(false)
  isBeta                Boolean  @default(false)
  disclaimerAcceptedAt  DateTime?
  disclaimerVersion     String?
  dni                   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  credits             UserCredit[]
  bookings            Booking[]
  transactions        Transaction[]
  payments            Payment[]
  passwordResetTokens PasswordResetToken[]
  emailLogs           EmailLog[]
  adminLogsAsAdmin         AdminAuditLog[] @relation("AdminLogs")
  adminLogsAsTarget        AdminAuditLog[] @relation("TargetLogs")
  notificationPreferences  NotificationPreference[]
  userGoals           UserGoal[]
}

model Goal {
  id        String     @id @default(uuid())
  label     String     @unique
  sortOrder Int
  isActive  Boolean    @default(true)
  userGoals UserGoal[]
}

model UserGoal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, goalId])
}

model Package {
  id            String   @id @default(cuid())
  name          String
  description   String?
  classCount    Int
  price         Float
  active        Boolean  @default(true)
  durationDays  Int      @default(30)
  stripePriceId        String?  @unique
  isStudentPackage     Boolean  @default(false)
  studentStripePriceId String?  @unique
  createdAt            DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user_id       String?  @db.Uuid

  transactions Transaction[]
  payments     Payment[]
  userCredits  UserCredit[]
}

model UserCredit {
  id               String    @id @default(cuid())
  userId           String
  creditsRemaining Int
  creditsTotal     Int
  expiresAt        DateTime?
  packageId        String?
  stripePaymentId  String?
  createdAt        DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  package  Package?  @relation(fields: [packageId], references: [id])
  bookings Booking[]
}

model Class {
  id          String   @id @default(cuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  capacity    Int
  bookedCount Int      @default(0)
  instructor  String?
  createdAt   DateTime @default(now())

  bookings Booking[]
}

model Booking {
  id              String    @id @default(cuid())
  userId          String
  classId         String
  stretcherNumber Int?
  status          String    @default("confirmed")
  userCreditId    String?
  creditLost      Boolean   @default(false)
  cancelledAt     DateTime?
  attendedAt      DateTime?
  createdAt       DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  userCredit UserCredit? @relation(fields: [userCreditId], references: [id])

  @@unique([userId, classId])
  @@unique([classId, stretcherNumber])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  packageId       String
  amount          Float
  stripePaymentId String?
  status          String
  createdAt       DateTime @default(now())
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  packageId         String
  amount            Float
  stripeSessionId   String   @unique
  stripePaymentId   String?
  status            String   @default("pending")
  createdAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  subject   String
  htmlBody  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminLogs", fields: [adminId], references: [id])
  targetUserId String
  targetUser   User     @relation("TargetLogs", fields: [targetUserId], references: [id])
  action       String
  metadata     Json?
  performedAt  DateTime @default(now())
}

// One row per (userId, type) — add new types as new rows, no schema change needed
model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'booking_confirmation' | 'booking_cancellation' | 'package_purchase'
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model EmailLog {
  id       String   @id @default(cuid())
  userId   String?
  to       String
  type     String
  subject  String
  status   String
  metadata Json?
  sentAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}